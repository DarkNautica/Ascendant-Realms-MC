{
  "version": 1,
  "status": "starter dynamic CustomNPCs identity script implemented; custom client overlay still reserved for the final animated nameplate layer",
  "reference_style": "clean two-line nameplate: [ C-Rank ] Mira Ash / Lv. 34 Scout",
  "forge_policy": {
    "do_not_install_bukkit_plugins": true,
    "current_fallback": "FTB Ranks and vanilla scoreboard/team prefixes for players; CustomNPCs scripted always-visible rank/name/level/role line for authored NPCs.",
    "likely_custom_mod": "Ascendant Nameplates client overlay if vanilla/NPC fallbacks cannot render the final styled two-line plate."
  },
  "customnpcs_script": {
    "file": "customnpcs/scripts/ecmascript/ascendant_npc_identity.js",
    "profile_key_source": "temporary NPC name or profile-key name tag such as ar:mira_ash",
    "current_level_source": "profile baseline inside the script",
    "future_level_source": "stored ar_level or a custom helper mod after baseline script validation",
    "behavior": "The script reads the NPC's temporary profile key and rewrites the NPC display name into one always-visible rank/name/level/role line. Profile tags like ar:mira_ash are setup keys, not final visible labels. The CustomNPCs title slot is intentionally cleared because the renderer only shows it at close range and wraps it in angle brackets."
  },
