{
  "version": 1,
  "last_updated": "2026-06-22",
  "status": "active_region_based_difficulty_multiplier",
  "enabled": true,
  "goal": "Keep Ascendant Realms dangerous immediately, but make the difficulty multiplier come from Atlas region identity instead of time, day count, or chunk residence duration.",
  "implementation": {
    "runtime_script": "kubejs/server_scripts/ascendant_regional_difficulty.js",
    "region_scoreboard": "ar_atlas_region",
    "ring_scoreboard": "ar_atlas_ring",
    "uses_day_count": false,
    "uses_time_of_day": false,
    "uses_crd": false,
    "nearest_player_radius": 112
  },
  "eligibility": {
    "hostile_only": true,
    "exclude_players": true,
    "exclude_npc_namespaces": [
      "customnpcs",
      "easy_npc",
      "mca"
    ],
    "excluded_entity_ids": [
      "minecraft:player",
      "minecraft:armor_stand",
      "minecraft:item",
      "minecraft:experience_orb",
      "minecraft:ender_dragon",
      "minecraft:wither"
    ],
    "notes": [
      "This layer does not add boss or dragon spawns.",
      "This layer only strengthens eligible hostiles that already spawned from vanilla, modded, Spawn Balance Utility, or In Control rules.",
      "Open-sky daylight burning undead are still not injected by the Ascendant spawner rules."
    ]
  },
