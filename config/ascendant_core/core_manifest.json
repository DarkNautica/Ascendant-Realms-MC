    },
    {
      "id": "ar_structures_done",
      "label": "Structures",
      "color": "aqua",
      "purpose": "structure clear milestone counter"
    },
    {
      "id": "ar_bosses_done",
      "label": "Bosses",
      "color": "red",
      "purpose": "major boss proof counter"
    },
    {
      "id": "ar_dragons_done",
      "label": "Dragons",
      "color": "dark_purple",
      "purpose": "dragon-tier proof counter"
    },
    {
      "id": "ar_region_tier",
      "label": "Region Tier",
      "color": "dark_aqua",
      "purpose": "future region/distance danger mirror"
    },
    {
