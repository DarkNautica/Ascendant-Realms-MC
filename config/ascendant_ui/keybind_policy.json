{
  "version": 1,
  "last_updated": "2026-06-18",
  "status": "active_client_keybind_policy",
  "scope": "Applied to the active CurseForge options.txt by scripts/sync-active-client-files.ps1 while preserving unrelated video, audio, resource-pack, and personal option lines.",
  "principles": [
    "Preserve vanilla movement, inventory, chat, screenshot, perspective, hotbar, attack, use, drop, sneak, sprint, and command keys.",
    "Keep core Ascendant RPG surfaces on simple keys: skills, quest log, spell wheel, spell cast, combat roll, backpack, curios, and map screens.",
    "Move duplicate gameplay controls to modifier chords or mouse side buttons when the mod action is still useful.",
    "Unbind non-gameplay or low-frequency menu/debug controls such as shader reload, shader toggle, shader-pack selection, cinematic scene controls, creative toolbar save/load, and title-selection menu.",
    "Prefer future in-game settings screens or commands for visual/debug actions rather than spending prime combat keys."
  ],
